#!/usr/bin/env python3

import subprocess
import argparse


def get_volume():
    return float(
        subprocess.check_output(
            "wpctl get-volume @DEFAULT_SINK@ | awk '{print $2}'",
            shell=True,
        )
        .strip()
        .decode("utf-8")
    )


def notify_volume():
    subprocess.call(f"notify-send Volume: {round(get_volume() * 100)}%", shell=True)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("-i", "--increase", type=int)
    parser.add_argument("-d", "--decrease", type=int)
    parser.add_argument("-t", "--toggle", action=argparse.BooleanOptionalAction)
    args = parser.parse_args()

    if args.increase:
        subprocess.call(
            f"wpctl set-volume @DEFAULT_SINK@ {args.increase / 100}+", shell=True
        )
    elif args.decrease:
        if int(get_volume()) >= 100:
            pass
        elif int(get_volume()) + args.decrease / 100 >= 100:
            subprocess.call("wpctl set-volume @DEFAULT_SINK@ 1", shell=True)
        else:
            subprocess.call(
                f"wpctl set-volume @DEFAULT_SINK@ {args.decrease / 100}-", shell=True
            )
    elif args.toggle:
        subprocess.call("wpctl set-mute @DEFAULT_SINK@ toggle", shell=True)
    notify_volume()


if __name__ == "__main__":
    main()
